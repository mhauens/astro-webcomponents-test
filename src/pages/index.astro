---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPackageInstructions } from '@/lib/packageInstructions';

const packageName = import.meta.env.PUBLIC_WEB_COMPONENTS_PACKAGE ?? '@mhauens/accordion';
const instructions = getPackageInstructions(packageName);
---

<script>
  import '@/components/WebComponentLoader';
</script>

<BaseLayout
  title="Astro Accordion Demo"
  description="Startseite mit der Web Component @mhauens/accordion in einem Astro-Projekt."
>
  <main class="hero">
    <section class="card stack">
      <p class="eyebrow">Astro + Web Components</p>
      <h1>Accordion-Komponente direkt auf der Startseite</h1>
      <p class="lead">
        Die Komponente <code>{packageName}</code> wird beim Laden der Seite registriert und kann
        danach direkt im Astro-Markup verwendet werden.
      </p>

      <div class="notice">
        <strong>{instructions.headline}</strong>
        <p>{instructions.body}</p>
      </div>

      <ol class="steps">
        <li>
          Die Registrierung läuft in einem Browser-Script, das
          <code>src/components/WebComponentLoader.ts</code> lädt.
        </li>
        <li>
          Danach kannst du <code>&lt;wc-accordion&gt;</code> wie jedes andere HTML-Tag direkt in
          Astro einsetzen.
        </li>
        <li>
          Inhalte für den aufgeklappten Bereich kommen per Slot aus dem umgebenden Markup.
        </li>
      </ol>
    </section>

    <section class="card stack">
      <h2>Live-Beispiel</h2>
      <p>
        Die erste Accordion-Instanz startet geöffnet, die zweite geschlossen.
      </p>

      <div class="demo stack">
        <wc-accordion heading="Was ist @mhauens/accordion?" open>
          <p>
            Eine als npm-Paket veröffentlichte Web Component, die sich nach dem Import selbst als
            <code>wc-accordion</code> registriert.
          </p>
        </wc-accordion>

        <wc-accordion heading="Wie verwende ich die Komponente in Astro?">
          <p>
            Importiere das Paket einmal zentral und nutze anschließend das Tag direkt in deinen
            Astro-Dateien. Zusätzliche Wrapper oder Framework-spezifische Bindings sind nicht
            nötig.
          </p>
        </wc-accordion>
      </div>

      <pre><code>{`---
---

<script>
  import '@/components/WebComponentLoader';
</script>

<wc-accordion heading="Beispiel" open>
  <p>Inhalt aus dem Astro-Markup</p>
</wc-accordion>`}</code></pre>
    </section>
  </main>
</BaseLayout>

<style>
  .hero {
    width: min(1100px, calc(100% - 3rem));
    margin: 0 auto;
    padding: 4rem 0;
    display: grid;
    gap: 1.5rem;
  }

  .card {
    background: rgba(15, 23, 42, 0.75);
    border: 1px solid rgba(125, 211, 252, 0.2);
    border-radius: 24px;
    padding: 2rem;
    box-shadow: 0 24px 60px rgba(15, 23, 42, 0.35);
  }

  .stack > * + * {
    margin-top: 1rem;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #38bdf8;
    font-size: 0.85rem;
    margin: 0;
  }

  h1,
  h2,
  p,
  ol {
    margin: 0;
  }

  .lead {
    max-width: 60ch;
    line-height: 1.6;
    color: #cbd5e1;
  }

  .lead code,
  .steps code,
  .demo code {
    font-size: 0.95em;
  }

  .notice {
    padding: 1rem 1.25rem;
    border-radius: 16px;
    background: rgba(14, 165, 233, 0.15);
    border: 1px solid rgba(125, 211, 252, 0.25);
  }

  .notice p {
    margin-top: 0.4rem;
  }

  .steps {
    padding-left: 1.25rem;
    display: grid;
    gap: 0.75rem;
    color: #cbd5e1;
  }

  .demo {
    gap: 0.75rem;
  }

  .demo p {
    margin: 0;
    line-height: 1.6;
    color: #cbd5e1;
  }

  code,
  pre {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
  }

  pre {
    padding: 1rem;
    overflow-x: auto;
    border-radius: 16px;
    background: rgba(2, 6, 23, 0.9);
    border: 1px solid rgba(148, 163, 184, 0.2);
  }

  @media (min-width: 900px) {
    .hero {
      grid-template-columns: 1.5fr 1fr;
      align-items: start;
    }
  }
</style>

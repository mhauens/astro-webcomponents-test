---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPackageInstructions } from '@/lib/packageInstructions';

const packageNames = ['@mhauens/accordion', '@mhauens/toggle'];
const configuredPackageName = import.meta.env.PUBLIC_WEB_COMPONENTS_PACKAGE;
const highlightedPackages = configuredPackageName ? [configuredPackageName] : packageNames;
const instructions = getPackageInstructions(highlightedPackages);
---

<script>
  import '@/components/WebComponentLoader';

  const connectToggleStatus = () => {
    const toggle = document.querySelector('wc-toggle[data-demo-toggle]');
    const status = document.querySelector<HTMLElement>('[data-toggle-status]');

    if (!(toggle instanceof HTMLElement) || !status) {
      return;
    }

    const syncStatus = () => {
      status.textContent = toggle.hasAttribute('checked') ? 'aktiviert' : 'deaktiviert';
    };

    toggle.addEventListener('change', syncStatus);
    syncStatus();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', connectToggleStatus, { once: true });
  } else {
    connectToggleStatus();
  }
</script>

<BaseLayout
  title="Astro Web Components Demo"
  description="Startseite mit den Web Components @mhauens/accordion und @mhauens/toggle in einem Astro-Projekt."
>
  <main class="hero">
    <section class="card stack">
      <p class="eyebrow">Astro + Web Components</p>
      <h1>Accordion und Toggle direkt auf der Startseite</h1>
      <p class="lead">
        Die Pakete <code>{highlightedPackages.join(' + ')}</code> werden beim Laden der Seite
        registriert und ihre Custom Elements stehen danach direkt im Astro-Markup bereit.
      </p>

      <div class="notice">
        <strong>{instructions.headline}</strong>
        <p>{instructions.body}</p>
      </div>

      <ol class="steps">
        <li>
          Die Registrierung läuft in einem Browser-Script, das
          <code>src/components/WebComponentLoader.ts</code> lädt.
        </li>
        <li>
          Danach kannst du <code>&lt;wc-accordion&gt;</code> und <code>&lt;wc-toggle&gt;</code>
          wie jedes andere HTML-Tag direkt in Astro einsetzen.
        </li>
        <li>
          Inhalte für das Accordion und die Beschreibung des Toggles kommen per Slot aus dem
          umgebenden Markup.
        </li>
      </ol>
    </section>

    <section class="card stack">
      <h2>Live-Beispiel</h2>
      <p>
        Das Accordion zeigt statische Inhalte, der Toggle aktualisiert zusätzlich live seinen
        Status auf der Seite.
      </p>

      <div class="demo stack">
        <wc-accordion class="brand-accordion" heading="Was ist @mhauens/accordion?" open>
          <p>
            Eine als npm-Paket veröffentlichte Web Component, die sich nach dem Import selbst als
            <code>wc-accordion</code> registriert.
          </p>
        </wc-accordion>

        <wc-accordion class="brand-accordion" heading="Wie verwende ich die Komponente in Astro?">
          <p>
            Importiere das Paket einmal zentral und nutze anschließend das Tag direkt in deinen
            Astro-Dateien. Zusätzliche Wrapper oder Framework-spezifische Bindings sind nicht
            nötig.
          </p>
        </wc-accordion>

        <div class="toggle-demo stack">
          <wc-toggle data-demo-toggle label="Release-Updates" checked>
            Benachrichtige mich, wenn neue Versionen der Web Components veröffentlicht werden.
          </wc-toggle>
          <p class="toggle-status">
            Aktueller Status: <strong data-toggle-status>aktiviert</strong>
          </p>
        </div>
      </div>

      <pre><code>{`---
---

<script>
  import '@/components/WebComponentLoader';
</script>

<wc-accordion class="brand-accordion" heading="Beispiel" open>
  <p>Inhalt aus dem Astro-Markup</p>
</wc-accordion>

<wc-toggle label="Benachrichtigungen" checked>
  Option direkt im Astro-Markup definieren
</wc-toggle>`}</code></pre>
    </section>
  </main>
</BaseLayout>

<style>
  .hero {
    width: min(1100px, calc(100% - 3rem));
    margin: 0 auto;
    padding: 4rem 0;
    display: grid;
    gap: 1.5rem;
  }

  .card {
    background: rgba(15, 23, 42, 0.75);
    border: 1px solid rgba(125, 211, 252, 0.2);
    border-radius: 24px;
    padding: 2rem;
    box-shadow: 0 24px 60px rgba(15, 23, 42, 0.35);
  }

  .stack > * + * {
    margin-top: 1rem;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #38bdf8;
    font-size: 0.85rem;
    margin: 0;
  }

  h1,
  h2,
  p,
  ol {
    margin: 0;
  }

  .lead {
    max-width: 60ch;
    line-height: 1.6;
    color: #cbd5e1;
  }

  .lead code,
  .steps code,
  .demo code {
    font-size: 0.95em;
  }

  .notice {
    padding: 1rem 1.25rem;
    border-radius: 16px;
    background: rgba(14, 165, 233, 0.15);
    border: 1px solid rgba(125, 211, 252, 0.25);
  }

  .notice p {
    margin-top: 0.4rem;
  }

  .steps {
    padding-left: 1.25rem;
    display: grid;
    gap: 0.75rem;
    color: #cbd5e1;
  }

  .demo {
    gap: 0.75rem;
  }

  .brand-accordion {
    --wc-accordion-width: 100%;
    --wc-accordion-border: 1px solid rgba(125, 211, 252, 0.28);
    --wc-accordion-radius: 1.25rem;
    --wc-accordion-background: linear-gradient(180deg, rgba(15, 23, 42, 0.96) 0%, rgba(15, 23, 42, 0.82) 100%);
    --wc-accordion-shadow: 0 20px 40px rgba(2, 6, 23, 0.35);
    --wc-accordion-color: #e2e8f0;
    --wc-accordion-trigger-gap: 1.25rem;
    --wc-accordion-trigger-padding: 1rem 1.25rem;
    --wc-accordion-trigger-background: linear-gradient(180deg, rgba(15, 23, 42, 0.78) 0%, rgba(30, 41, 59, 0.92) 100%);
    --wc-accordion-trigger-color: #f8fafc;
    --wc-accordion-focus-outline: 3px solid rgba(56, 189, 248, 0.9);
    --wc-accordion-focus-outline-offset: -2px;
    --wc-accordion-icon-color: #7dd3fc;
    --wc-accordion-panel-background: linear-gradient(180deg, rgba(14, 165, 233, 0.08) 0%, rgba(15, 23, 42, 0) 100%);
    --wc-accordion-panel-padding: 0 1.25rem 1.1rem;
    --wc-accordion-panel-color: #cbd5e1;
  }

  .brand-accordion::part(trigger) {
    letter-spacing: 0.01em;
  }

  .brand-accordion::part(heading) {
    font-size: 1rem;
  }

  .brand-accordion::part(body) {
    line-height: 1.65;
  }

  .brand-accordion::part(icon) {
    font-size: 1.15rem;
  }

  .toggle-demo {
    padding: 1rem 1.25rem;
    border-radius: 18px;
    background: rgba(15, 23, 42, 0.55);
    border: 1px solid rgba(148, 163, 184, 0.18);
  }

  .demo p {
    margin: 0;
    line-height: 1.6;
    color: #cbd5e1;
  }

  .toggle-status strong {
    color: #7dd3fc;
  }

  code,
  pre {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
  }

  pre {
    padding: 1rem;
    overflow-x: auto;
    border-radius: 16px;
    background: rgba(2, 6, 23, 0.9);
    border: 1px solid rgba(148, 163, 184, 0.2);
  }

  @media (min-width: 900px) {
    .hero {
      grid-template-columns: 1.5fr 1fr;
      align-items: start;
    }
  }
</style>
